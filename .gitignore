# ==============================================================
# Unreal Engine 5 .gitignore  (Project Metrush)
# 엔진이 자동 생성하는 폴더/파일은 버전 관리에서 제외한다.
# 이 파일들은 각자 PC에서 다시 생성되므로 올릴 필요가 없다.
# ==============================================================

# --- Visual Studio / Rider 사용자 설정 ---
.vs/
.idea/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj
*.xcworkspace

# --- 컴파일 산출물 ---
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.lib
*.a
*.la
*.lai
*.exe
*.out
*.app
*.ipa

# --- 언리얼 생성 폴더 (절대 올리지 말 것) ---
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
Plugins/*/Binaries/
Plugins/*/Intermediate/

# --- 맵 라이팅 빌드 데이터 (로컬에서 재생성) ---
*_BuiltData.uasset

# --- 기타 ---
*.tmp
*.log
*.bak

# Build 폴더 안의 아이콘은 예외적으로 포함
!Build/**/*.ico
